<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Management | Banquet System</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="../../public/assets/css/theme.css" rel="stylesheet">
<link href="../../public/assets/css/app.css"   rel="stylesheet">
</head>
<body>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
    <a href="../dashboard/index.html" class="sidebar-brand"><div class="sidebar-brand-icon">🏛</div><span class="sidebar-brand-text">BanquetPro</span></a>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a href="../dashboard/index.html" class="sidebar-link"><span class="sidebar-icon">📊</span><span class="sidebar-text">Dashboard</span></a>
        <div class="nav-section-label">Bookings</div>
        <a href="../bookings/index.html" class="sidebar-link"><span class="sidebar-icon">📅</span><span class="sidebar-text">All Bookings</span></a>
        <div class="nav-section-label">Finance</div>
        <a href="../payments/index.html" class="sidebar-link"><span class="sidebar-icon">💰</span><span class="sidebar-text">Payments</span></a>
        <a href="../invoices/index.html" class="sidebar-link"><span class="sidebar-icon">🧾</span><span class="sidebar-text">Invoices</span></a>
        <div class="nav-section-label">Admin</div>
        <a href="index.html" class="sidebar-link active"><span class="sidebar-icon">👤</span><span class="sidebar-text">Users</span></a>
        <a href="../settings/index.html" class="sidebar-link"><span class="sidebar-icon">⚙️</span><span class="sidebar-text">Settings</span></a>
    </nav>
    <div class="sidebar-footer"><div style="display:flex;align-items:center;gap:10px;padding:8px"><div class="avatar" data-user-avatar style="width:34px;height:34px;font-size:12px"></div><div class="sidebar-text"><div style="color:white;font-size:13px;font-weight:600" data-user-name></div></div></div></div>
</aside>

<div class="main-content" id="mainContent">
    <header class="topbar">
        <button class="topbar-toggle" id="sidebarToggle">☰</button>
        <nav class="breadcrumb-nav"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="../dashboard/index.html">Home</a></li><li class="breadcrumb-item active">User Management</li></ol></nav>
        <div class="topbar-actions">
            <button class="topbar-btn" id="themeToggle"><span id="themeIcon">🌙</span></button>
            <div class="dropdown"><button class="avatar-btn" data-bs-toggle="dropdown"><div class="avatar" data-user-avatar></div></button><ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item danger" href="#" data-action="logout">🚪 Log Out</a></li></ul></div>
        </div>
    </header>

    <main class="page-content">
        <div class="page-header">
            <div><h1 class="page-title">User Management</h1><p class="page-subtitle">Manage staff accounts, roles and permissions</p></div>
            <button class="btn-primary-brand" onclick="openModal()">➕ Add User</button>
        </div>

        <!-- Role KPIs -->
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:22px" id="roleKPIs">
            <div class="kpi-card"><div class="kpi-label">Super Admins</div><div class="kpi-value" id="kpiSA">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Company Admins</div><div class="kpi-value" id="kpiCA">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Branch Managers</div><div class="kpi-value" id="kpiBM">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Booking Execs</div><div class="kpi-value" id="kpiBE">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Total Active</div><div class="kpi-value" id="kpiActive" style="color:var(--color-success)">—</div></div>
        </div>

        <!-- Filters -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px">
            <div class="search-input-wrap">
                <span class="search-icon">🔍</span>
                <input type="text" class="form-control" id="userSearch" placeholder="Name, email, branch…" oninput="handleSearch(this.value)">
            </div>
            <select class="form-select" id="roleFilter" onchange="loadUsers(1)" style="width:auto">
                <option value="">All Roles</option>
                <option value="1">Super Admin</option>
                <option value="2">Company Admin</option>
                <option value="3">Branch Manager</option>
                <option value="4">Booking Executive</option>
            </select>
            <select class="form-select" id="statusFilter" onchange="loadUsers(1)" style="width:auto">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="suspended">Suspended</option>
            </select>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>User</th><th>Role</th><th>Branch</th><th>Last Login</th><th>Status</th><th>2FA</th><th style="width:120px">Actions</th></tr>
                    </thead>
                    <tbody id="usersBody">
                        <tr><td colspan="7" class="text-center py-4"><span class="spinner-border spinner-border-sm"></span></td></tr>
                    </tbody>
                </table>
            </div>
            <div id="userPagination"></div>
        </div>
    </main>
    <footer style="padding:16px 24px;border-top:1px solid var(--border-color);text-align:center;font-size:12px;color:var(--text-muted)">© 2026 BanquetPro</footer>
</div>

<!-- Add/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="modalTitle">Add User</h5><button class="btn-close" data-bs-dismiss="modal">×</button></div>
            <div class="modal-body">
                <input type="hidden" id="userId">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">First Name *</label><input type="text" class="form-control" id="uFirstName" placeholder="Ravi"></div>
                    <div class="col-md-6"><label class="form-label">Last Name *</label><input type="text" class="form-control" id="uLastName" placeholder="Kumar"></div>
                    <div class="col-md-6"><label class="form-label">Email *</label><input type="email" class="form-control" id="uEmail" placeholder="ravi@company.com"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="tel" class="form-control" id="uPhone" placeholder="+91 98765 43210"></div>
                    <div class="col-md-6">
                        <label class="form-label">Role *</label>
                        <select class="form-select" id="uRole">
                            <option value="">Select Role</option>
                            <option value="2">Company Admin</option>
                            <option value="3">Branch Manager</option>
                            <option value="4">Booking Executive</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Branch</label>
                        <select class="form-select" id="uBranch">
                            <option value="">All Branches</option>
                            <option value="1">Main Branch</option>
                            <option value="2">North Branch</option>
                            <option value="3">South Branch</option>
                        </select>
                    </div>
                    <div class="col-md-6" id="passFieldWrap">
                        <label class="form-label">Password *</label>
                        <input type="password" class="form-control" id="uPassword" placeholder="Min 8 chars, 1 number, 1 special">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="uStatus">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" data-bs-dismiss="modal">Cancel</button>
                <button class="btn-primary-brand" id="saveUserBtn" onclick="saveUser()">💾 Save User</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<button id="scrollTop">↑</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="../../public/assets/js/api.js"></script>
<script src="../../public/assets/js/utils.js"></script>
<script src="../../public/assets/js/auth.js"></script>
<script src="../../public/assets/js/app.js"></script>
<script>
Auth.requireAuth('../auth/login.html');
Auth.requireRole([1, 2]);   // Super Admin or Company Admin only

const DEMO_USERS = [
    { user_id:1,  first_name:'Suresh',  last_name:'Mehta',    email:'suresh@banquetpro.in',   role_name:'Super Admin',        branch_name:'—',            last_login:'30 Jun 2026',  status:'active',   two_fa:true  },
    { user_id:2,  first_name:'Kavita',  last_name:'Sharma',   email:'kavita@royalheritage.in', role_name:'Company Admin',      branch_name:'All Branches', last_login:'29 Jun 2026',  status:'active',   two_fa:true  },
    { user_id:3,  first_name:'Ravi',    last_name:'Kumar',    email:'ravi@royalheritage.in',   role_name:'Branch Manager',     branch_name:'Main Branch',  last_login:'28 Jun 2026',  status:'active',   two_fa:false },
    { user_id:4,  first_name:'Pooja',   last_name:'Verma',    email:'pooja@royalheritage.in',  role_name:'Booking Executive',  branch_name:'Main Branch',  last_login:'30 Jun 2026',  status:'active',   two_fa:false },
    { user_id:5,  first_name:'Amit',    last_name:'Singh',    email:'amit@royalheritage.in',   role_name:'Booking Executive',  branch_name:'Main Branch',  last_login:'27 Jun 2026',  status:'active',   two_fa:false },
    { user_id:6,  first_name:'Deepa',   last_name:'Nair',     email:'deepa@royalheritage.in',  role_name:'Branch Manager',     branch_name:'North Branch', last_login:'25 Jun 2026',  status:'active',   two_fa:false },
    { user_id:7,  first_name:'Sandeep', last_name:'Joshi',    email:'sandeep@royalheritage.in',role_name:'Booking Executive',  branch_name:'North Branch', last_login:'22 Jun 2026',  status:'inactive', two_fa:false },
];

const ROLE_COLORS = { 'Super Admin':'#7C3AED','Company Admin':'#2563EB','Branch Manager':'#10B981','Booking Executive':'#F59E0B' };

async function loadUsers(page = 1) {
    const tbody = document.getElementById('usersBody');
    tbody.innerHTML = '<tr><td colspan="7" class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></td></tr>';
    try {
        const res   = await API.users.list({ page, limit:20,
            search: document.getElementById('userSearch').value || undefined,
            role:   document.getElementById('roleFilter').value   || undefined,
            status: document.getElementById('statusFilter').value  || undefined,
        });
        const users = res.data?.users || [];
        renderUsers(users);
        updateKPIs(res.data?.stats || {});
        Utils.renderPagination('userPagination', { page, limit:20, total: res.data?.meta?.total || users.length }, loadUsers);
    } catch {
        renderUsers(DEMO_USERS);
        updateKPIs({ super_admin:1, company_admin:1, branch_manager:2, booking_exec:3, active:6 });
        Utils.renderPagination('userPagination', { page:1, limit:20, total:7 }, loadUsers);
    }
}

function renderUsers(users) {
    const tbody = document.getElementById('usersBody');
    if (!users.length) { tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state" style="padding:24px">No users found</div></td></tr>'; return; }
    const me = Auth.getUser()?.user_id;
    tbody.innerHTML = users.map(u => `
    <tr>
        <td>
            <div style="display:flex;align-items:center;gap:10px">
                <div class="avatar" style="width:34px;height:34px;font-size:12px;background:${ROLE_COLORS[u.role_name]||'#7C3AED'};color:#fff">${Utils.initials(u.first_name + ' ' + u.last_name)}</div>
                <div>
                    <div style="font-weight:600;font-size:13px">${u.first_name} ${u.last_name}${u.user_id === me ? ' <span style="font-size:10px;color:var(--brand-primary)">(you)</span>' : ''}</div>
                    <div style="font-size:12px;color:var(--text-muted)">${u.email}</div>
                </div>
            </div>
        </td>
        <td><span style="background:${ROLE_COLORS[u.role_name]}20;color:${ROLE_COLORS[u.role_name]};padding:3px 8px;border-radius:20px;font-size:11.5px;font-weight:600">${u.role_name}</span></td>
        <td style="font-size:12.5px">${u.branch_name || '—'}</td>
        <td style="font-size:12px;color:var(--text-muted)">${u.last_login || '—'}</td>
        <td>${Utils.statusBadge(u.status)}</td>
        <td>${u.two_fa ? '<span style="color:var(--color-success)">✅</span>' : '<span style="color:var(--text-muted)">—</span>'}</td>
        <td>
            <div style="display:flex;gap:4px">
                <button class="btn-ghost" style="padding:4px 8px;font-size:12px" onclick="editUser(${u.user_id})" title="Edit">✏️</button>
                ${u.status === 'active' ? `<button class="btn-ghost" style="padding:4px 8px;font-size:12px;color:var(--color-warning)" onclick="toggleStatus(${u.user_id},'inactive')" title="Deactivate">🔒</button>` : `<button class="btn-ghost" style="padding:4px 8px;font-size:12px;color:var(--color-success)" onclick="toggleStatus(${u.user_id},'active')" title="Activate">🔓</button>`}
                <button class="btn-ghost" style="padding:4px 8px;font-size:12px" onclick="resetPassword(${u.user_id})" title="Reset Password">🔑</button>
            </div>
        </td>
    </tr>`).join('');
}

function updateKPIs(s) {
    document.getElementById('kpiSA').textContent     = s.super_admin    ?? 1;
    document.getElementById('kpiCA').textContent     = s.company_admin  ?? 1;
    document.getElementById('kpiBM').textContent     = s.branch_manager ?? 2;
    document.getElementById('kpiBE').textContent     = s.booking_exec   ?? 3;
    document.getElementById('kpiActive').textContent = s.active         ?? 6;
}

let userModalInst, editingId = null;
function openModal(user = null) {
    editingId = user?.user_id || null;
    document.getElementById('modalTitle').textContent = user ? 'Edit User' : 'Add User';
    document.getElementById('userId').value     = user?.user_id || '';
    document.getElementById('uFirstName').value = user?.first_name || '';
    document.getElementById('uLastName').value  = user?.last_name  || '';
    document.getElementById('uEmail').value     = user?.email      || '';
    document.getElementById('uPhone').value     = user?.phone      || '';
    document.getElementById('uStatus').value    = user?.status     || 'active';
    document.getElementById('passFieldWrap').style.display = user ? 'none' : '';
    userModalInst = new bootstrap.Modal(document.getElementById('userModal'));
    userModalInst.show();
}

function editUser(id) {
    const u = DEMO_USERS.find(u => u.user_id === id);
    openModal(u || { user_id: id });
}

async function saveUser() {
    const btn  = document.getElementById('saveUserBtn');
    const data = {
        first_name: document.getElementById('uFirstName').value.trim(),
        last_name:  document.getElementById('uLastName').value.trim(),
        email:      document.getElementById('uEmail').value.trim(),
        phone:      document.getElementById('uPhone').value.trim(),
        role_id:    parseInt(document.getElementById('uRole').value),
        branch_id:  document.getElementById('uBranch').value ? parseInt(document.getElementById('uBranch').value) : null,
        status:     document.getElementById('uStatus').value,
        password:   document.getElementById('uPassword')?.value || undefined,
    };
    if (!data.first_name || !data.last_name || !data.email) { Utils.toast('First name, last name and email are required', 'error'); return; }
    Utils.showLoader(btn, 'Saving…');
    try {
        if (editingId) await API.users.update(editingId, data);
        else           await API.users.create(data);
        Utils.hideLoader(btn);
        userModalInst.hide();
        Utils.toast(editingId ? 'User updated!' : 'User created!', 'success');
        loadUsers(1);
    } catch {
        Utils.hideLoader(btn);
        userModalInst.hide();
        Utils.toast(editingId ? 'User updated (demo)' : 'User created (demo)', 'success');
        loadUsers(1);
    }
}

async function toggleStatus(id, newStatus) {
    const label = newStatus === 'active' ? 'activate' : 'deactivate';
    const ok = await Utils.confirm(`${Utils.titleCase(label)} this user?`, { danger: newStatus !== 'active' });
    if (!ok) return;
    try {
        await API.users.update(id, { status: newStatus });
    } catch { /* demo */ }
    Utils.toast(`User ${label}d`, newStatus === 'active' ? 'success' : 'warning');
    loadUsers(1);
}

async function resetPassword(id) {
    const ok = await Utils.confirm('Send password reset email to this user?', { title:'Reset Password' });
    if (!ok) return;
    try { await API.users.resetPassword(id); } catch { /* demo */ }
    Utils.toast('Password reset email sent', 'info');
}

const handleSearch = Utils.debounce(() => loadUsers(1), 350);
document.addEventListener('DOMContentLoaded', () => loadUsers(1));
</script>
</body>
</html>
