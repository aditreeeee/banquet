# ─────────────────────────────────────────────
# Banquet Hall Booking System — Environment Config
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME="Banquet Booking System"
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080
API_VERSION=v1

# ── Database (MSSQL) ───────────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_NAME=BanquetDB
DB_USER=sa
DB_PASSWORD=YourPassword123
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000
# Connection retry policy (exponential backoff: base doubles up to max, for
# at least DB_RETRY_BUDGET_MS before a single getPool() call gives up —
# the app-level startup wait then keeps retrying beyond that indefinitely)
DB_RETRY_BASE_MS=1000
DB_RETRY_MAX_MS=30000
DB_RETRY_BUDGET_MS=60000

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-min-64-chars-here
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-min-64-chars-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption ───────────────────────────────
ENCRYPTION_KEY=your-32-char-aes-256-key-here-000
ENCRYPTION_IV=your-16-char-iv00

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── File Upload ───────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,webp
UPLOAD_PATH=./uploads

# ── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME="Banquet Booking System"
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ── SMS (Twilio / MSG91) ─────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=BANQTS
MSG91_ROUTE=4

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=30d
LOG_MAX_SIZE=50m

# ── Session / Cookie ──────────────────────────
COOKIE_SECRET=your-cookie-secret-min-32-chars-here
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# ── Super Admin (first-run seed) ─────────────
SUPER_ADMIN_EMAIL=superadmin@banquetsys.com
SUPER_ADMIN_PASSWORD=Admin@1234

# ── PDF Generation ────────────────────────────
PDF_PUPPETEER_EXECUTABLE=
PDF_UPLOAD_PATH=./uploads/invoices

# ── MSSQL Notes ────────────────────────────────
# Requires Microsoft SQL Server 2017+ (STRING_AGG support)
# Run: npm run db:setup (from backend/) after setting credentials — creates the
# database/schema idempotently. See docs/deployment/DEPLOYMENT.md for details.
# Set DB_ENCRYPT=true for Azure SQL / production; DB_TRUST_SERVER_CERTIFICATE=true
# only for local dev instances using a self-signed certificate.
