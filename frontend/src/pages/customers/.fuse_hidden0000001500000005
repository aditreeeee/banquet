<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customers | Banquet System</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="../../public/assets/css/theme.css" rel="stylesheet">
<link href="../../public/assets/css/app.css"   rel="stylesheet">
<style>
.customer-card { background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-lg); padding:18px; display:flex; align-items:flex-start; gap:14px; transition:box-shadow var(--transition-fast),transform var(--transition-fast); cursor:pointer; }
.customer-card:hover { box-shadow:var(--shadow-md); transform:translateY(-1px); }
.cust-avatar { width:44px; height:44px; border-radius:50%; background:var(--brand-primary); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; }
.cust-name   { font-size:14px; font-weight:700; color:var(--text-primary); }
.cust-meta   { font-size:12px; color:var(--text-muted); margin-top:2px; }
.cust-stats  { display:flex; gap:16px; margin-top:10px; }
.cust-stat   { text-align:center; }
.cust-stat .val { font-size:15px; font-weight:700; color:var(--text-primary); }
.cust-stat .lbl { font-size:10px; color:var(--text-muted); text-transform:uppercase; }
</style>
</head>
<body>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
    <a href="../dashboard/index.html" class="sidebar-brand"><div class="sidebar-brand-icon">🏛</div><span class="sidebar-brand-text">BanquetPro</span></a>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a href="../dashboard/index.html" class="sidebar-link"><span class="sidebar-icon">📊</span><span class="sidebar-text">Dashboard</span></a>
        <div class="nav-section-label">Venues</div>
        <a href="../banquets/index.html" class="sidebar-link"><span class="sidebar-icon">🏰</span><span class="sidebar-text">Banquets</span></a>
        <a href="../halls/index.html" class="sidebar-link"><span class="sidebar-icon">🚪</span><span class="sidebar-text">Halls</span></a>
        <div class="nav-section-label">Bookings</div>
        <a href="../bookings/index.html" class="sidebar-link"><span class="sidebar-icon">📅</span><span class="sidebar-text">All Bookings</span></a>
        <a href="../bookings/create.html" class="sidebar-link"><span class="sidebar-icon">➕</span><span class="sidebar-text">New Booking</span></a>
        <div class="nav-section-label">CRM</div>
        <a href="index.html" class="sidebar-link active"><span class="sidebar-icon">👥</span><span class="sidebar-text">Customers</span></a>
        <div class="nav-section-label">Finance</div>
        <a href="../payments/index.html" class="sidebar-link"><span class="sidebar-icon">💰</span><span class="sidebar-text">Payments</span></a>
        <a href="../invoices/index.html" class="sidebar-link"><span class="sidebar-icon">🧾</span><span class="sidebar-text">Invoices</span></a>
        <div class="nav-section-label">Reports</div>
        <a href="../reports/revenue.html" class="sidebar-link"><span class="sidebar-icon">📈</span><span class="sidebar-text">Revenue</span></a>
    </nav>
    <div class="sidebar-footer"><div style="display:flex;align-items:center;gap:10px;padding:8px"><div class="avatar" data-user-avatar style="width:34px;height:34px;font-size:12px"></div><div class="sidebar-text"><div style="color:white;font-size:13px;font-weight:600" data-user-name></div></div></div></div>
</aside>

<div class="main-content" id="mainContent">
    <header class="topbar">
        <button class="topbar-toggle" id="sidebarToggle">☰</button>
        <nav class="breadcrumb-nav"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="../dashboard/index.html">Home</a></li><li class="breadcrumb-item active">Customers</li></ol></nav>
        <div class="topbar-actions">
            <button class="topbar-btn" id="themeToggle"><span id="themeIcon">🌙</span></button>
            <div class="dropdown"><button class="avatar-btn" data-bs-toggle="dropdown"><div class="avatar" data-user-avatar></div></button><ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item danger" href="#" data-action="logout">🚪 Log Out</a></li></ul></div>
        </div>
    </header>

    <main class="page-content">
        <div class="page-header">
            <div><h1 class="page-title">Customers</h1><p class="page-subtitle">Manage customer profiles, booking history and loyalty</p></div>
            <div style="display:flex;gap:10px">
                <button class="btn-ghost" onclick="exportCsv()">⬇ Export</button>
                <button class="btn-primary-brand" onclick="openCustomerModal()">➕ Add Customer</button>
            </div>
        </div>

        <!-- Filter bar -->
        <div class="table-card" style="margin-bottom:20px">
            <div style="display:flex;gap:10px;flex-wrap:wrap;padding:14px 16px">
                <div class="search-input-wrap" style="max-width:320px">
                    <span class="search-icon">🔍</span>
                    <input type="text" class="form-control" id="custSearch" placeholder="Name, email, phone…" oninput="handleSearch(this.value)">
                </div>
                <select class="form-select" id="sortFilter" onchange="loadCustomers(1)" style="width:auto">
                    <option value="recent">Most Recent</option>
                    <option value="spend_desc">Highest Spend</option>
                    <option value="bookings_desc">Most Bookings</option>
                    <option value="name_asc">Name (A–Z)</option>
                </select>
                <select class="form-select" id="sourceFilter" onchange="loadCustomers(1)" style="width:auto">
                    <option value="">All Sources</option>
                    <option value="website">Website</option>
                    <option value="walkin">Walk-in</option>
                    <option value="referral">Referral</option>
                    <option value="social">Social Media</option>
                </select>
            </div>
        </div>

        <!-- Stats row -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px">
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px 16px;text-align:center">
                <div style="font-size:22px;font-weight:700;color:var(--text-primary)" id="totalCustomers">—</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Total Customers</div>
            </div>
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px 16px;text-align:center">
                <div style="font-size:22px;font-weight:700;color:var(--color-success)" id="newThisMonth">—</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px">New This Month</div>
            </div>
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px 16px;text-align:center">
                <div style="font-size:22px;font-weight:700;color:var(--brand-primary)" id="avgSpend">—</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Avg. Spend</div>
            </div>
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:14px 16px;text-align:center">
                <div style="font-size:22px;font-weight:700;color:var(--color-warning)" id="repeatCustomers">—</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Repeat Customers</div>
            </div>
        </div>

        <!-- Customer cards grid -->
        <div id="customersGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px"></div>
        <div id="paginationWrap" style="margin-top:16px"></div>
    </main>
    <footer style="padding:16px 24px;border-top:1px solid var(--border-color);text-align:center;font-size:12px;color:var(--text-muted)">© 2026 BanquetPro</footer>
</div>

<!-- Customer Modal -->
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="custModalTitle">Add Customer</h5><button class="btn-close" data-bs-dismiss="modal">×</button></div>
            <div class="modal-body">
                <input type="hidden" id="custId">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">First Name *</label><input type="text" class="form-control" id="custFirstName"></div>
                    <div class="col-md-6"><label class="form-label">Last Name *</label><input type="text" class="form-control" id="custLastName"></div>
                    <div class="col-12"><label class="form-label">Email *</label><input type="email" class="form-control" id="custEmail"></div>
                    <div class="col-12"><label class="form-label">Phone *</label><input type="tel" class="form-control" id="custPhone" placeholder="+91-XXXXXXXXXX"></div>
                    <div class="col-md-6"><label class="form-label">Source</label><select class="form-select" id="custSource"><option value="walkin">Walk-in</option><option value="website">Website</option><option value="referral">Referral</option><option value="social">Social</option></select></div>
                    <div class="col-md-6"><label class="form-label">City</label><input type="text" class="form-control" id="custCity" placeholder="Mumbai"></div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea class="form-control" id="custNotes" rows="2" placeholder="Special notes about this customer…"></textarea></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" data-bs-dismiss="modal">Cancel</button>
                <button class="btn-primary-brand" id="saveCustBtn" onclick="saveCustomer()">Save Customer</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<button id="scrollTop">↑</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="../../public/assets/js/api.js"></script>
<script src="../../public/assets/js/utils.js"></script>
<script src="../../public/assets/js/auth.js"></script>
<script src="../../public/assets/js/app.js"></script>
<script>
Auth.requireAuth('../auth/login.html');

const DEMO_CUSTOMERS = [
    { customer_id:1,  first_name:'Arjun',   last_name:'Sharma',      email:'arjun.sharma@gmail.com',    phone:'+91-9811001001', total_bookings:3, total_spend:465000, source:'website',  created_at:'2025-09-01' },
    { customer_id:2,  first_name:'Priya',   last_name:'Patel',       email:'priya.patel@gmail.com',     phone:'+91-9811001002', total_bookings:2, total_spend:215000, source:'referral', created_at:'2025-10-10' },
    { customer_id:3,  first_name:'Rahul',   last_name:'Gupta',       email:'rahul.gupta@yahoo.com',     phone:'+91-9811001003', total_bookings:5, total_spend:820000, source:'website',  created_at:'2025-08-20' },
    { customer_id:4,  first_name:'Anjali',  last_name:'Singh',       email:'anjali.singh@hotmail.com',  phone:'+91-9811001004', total_bookings:1, total_spend:148000, source:'walkin',   created_at:'2025-11-05' },
    { customer_id:5,  first_name:'Vikram',  last_name:'Mehta',       email:'vikram.mehta@gmail.com',    phone:'+91-9811001005', total_bookings:4, total_spend:680000, source:'website',  created_at:'2025-09-15' },
    { customer_id:6,  first_name:'Neha',    last_name:'Agarwal',     email:'neha.agarwal@gmail.com',    phone:'+91-9811001006', total_bookings:2, total_spend:290000, source:'social',   created_at:'2025-12-01' },
    { customer_id:7,  first_name:'Sanjay',  last_name:'Kumar',       email:'sanjay.kumar@gmail.com',    phone:'+91-9811001007', total_bookings:6, total_spend:940000, source:'referral', created_at:'2025-08-01' },
    { customer_id:8,  first_name:'Kavita',  last_name:'Joshi',       email:'kavita.joshi@rediff.com',   phone:'+91-9811001008', total_bookings:1, total_spend:88000,  source:'walkin',   created_at:'2025-12-15' },
    { customer_id:9,  first_name:'Aditya',  last_name:'Verma',       email:'aditya.verma@gmail.com',    phone:'+91-9811001009', total_bookings:3, total_spend:520000, source:'website',  created_at:'2025-10-20' },
    { customer_id:10, first_name:'Sunita',  last_name:'Rao',         email:'sunita.rao@gmail.com',      phone:'+91-9811001010', total_bookings:2, total_spend:310000, source:'social',   created_at:'2026-01-10' },
    { customer_id:11, first_name:'Manish',  last_name:'Tiwari',      email:'manish.tiwari@gmail.com',   phone:'+91-9811001011', total_bookings:1, total_spend:185000, source:'referral', created_at:'2026-02-01' },
    { customer_id:12, first_name:'Pooja',   last_name:'Nair',        email:'pooja.nair@gmail.com',      phone:'+91-9811001012', total_bookings:4, total_spend:620000, source:'website',  created_at:'2025-11-20' },
];

const AVATAR_COLORS = ['#7C3AED','#10B981','#F59E0B','#EF4444','#3B82F6','#EC4899','#14B8A6','#8B5CF6'];

async function loadCustomers(page = 1) {
    const grid = document.getElementById('customersGrid');
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:48px"><span class="spinner-border spinner-border-sm me-2"></span>Loading customers…</div>';

    try {
        const res  = await API.customers.list({
            page, limit: 12,
            search: document.getElementById('custSearch').value || undefined,
            source: document.getElementById('sourceFilter').value || undefined,
        });
        const list = res.data?.customers || [];
        const meta = res.data?.meta || { total: list.length, page, limit: 12 };
        renderCustomers(list);
        updateStats(res.data?.stats || {});
        Utils.renderPagination('paginationWrap', { page, limit: 12, total: meta.total }, loadCustomers);
    } catch {
        renderCustomers(DEMO_CUSTOMERS);
        updateStats({ total: 50, new_this_month: 8, avg_spend: 285000, repeat_customers: 22 });
        Utils.renderPagination('paginationWrap', { page:1, limit:12, total:50 }, loadCustomers);
    }
}

function renderCustomers(list) {
    const grid = document.getElementById('customersGrid');
    if (!list.length) {
        grid.innerHTML = '<div style="grid-column:1/-1"><div class="empty-state"><div class="empty-state-icon">👥</div><div class="empty-state-title">No customers found</div></div></div>';
        return;
    }
    grid.innerHTML = list.map((c, i) => {
        const name  = `${c.first_name} ${c.last_name}`;
        const color = AVATAR_COLORS[i % AVATAR_COLORS.length];
        const sourceChip = {
            website:'🌐 Website', walkin:'🚶 Walk-in',
            referral:'🤝 Referral', social:'📱 Social'
        }[c.source] || c.source;
        return `
        <div class="customer-card" onclick="window.location.href='detail.html?id=${c.customer_id}'">
            <div class="cust-avatar" style="background:${color}">${Utils.initials(name)}</div>
            <div style="flex:1;min-width:0">
                <div class="cust-name">${name}</div>
                <div class="cust-meta">${c.email}</div>
                <div class="cust-meta">${c.phone}</div>
                <div style="margin-top:6px"><span class="chip">${sourceChip}</span></div>
                <div class="cust-stats">
                    <div class="cust-stat">
                        <div class="val">${c.total_bookings}</div>
                        <div class="lbl">Bookings</div>
                    </div>
                    <div class="cust-stat">
                        <div class="val">${Utils.formatCurrency(c.total_spend)}</div>
                        <div class="lbl">Total Spent</div>
                    </div>
                    <div class="cust-stat">
                        <div class="val">${Utils.formatDate(c.created_at, { year:undefined, month:'short', day:'2-digit' })}</div>
                        <div class="lbl">Joined</div>
                    </div>
                </div>
            </div>
            <button class="btn-icon" onclick="event.stopPropagation();openCustomerModal(${JSON.stringify(c).replace(/"/g,'&quot;')})" title="Edit">✏️</button>
        </div>`;
    }).join('');
}

function updateStats(s) {
    document.getElementById('totalCustomers').textContent  = Utils.formatNumber(s.total           || 50);
    document.getElementById('newThisMonth').textContent   = Utils.formatNumber(s.new_this_month   || 8);
    document.getElementById('avgSpend').textContent       = Utils.formatCurrency(s.avg_spend       || 285000);
    document.getElementById('repeatCustomers').textContent= Utils.formatNumber(s.repeat_customers  || 22);
}

const handleSearch = Utils.debounce(() => loadCustomers(1), 350);

let custModalInstance;
function openCustomerModal(c = null) {
    document.getElementById('custModalTitle').textContent = c ? 'Edit Customer' : 'Add Customer';
    document.getElementById('custId').value        = c?.customer_id || '';
    document.getElementById('custFirstName').value = c?.first_name  || '';
    document.getElementById('custLastName').value  = c?.last_name   || '';
    document.getElementById('custEmail').value     = c?.email       || '';
    document.getElementById('custPhone').value     = c?.phone       || '';
    document.getElementById('custSource').value    = c?.source      || 'walkin';
    custModalInstance = new bootstrap.Modal(document.getElementById('customerModal'));
    custModalInstance.show();
}

async function saveCustomer() {
    const btn = document.getElementById('saveCustBtn');
    const fn  = document.getElementById('custFirstName').value.trim();
    const ln  = document.getElementById('custLastName').value.trim();
    const em  = document.getElementById('custEmail').value.trim();
    const ph  = document.getElementById('custPhone').value.trim();
    if (!fn || !ln || !em || !ph) { Utils.toast('Please fill all required fields', 'error'); return; }
    if (!Utils.Validators.email(em)) { Utils.toast('Please enter a valid email', 'error'); return; }

    Utils.showLoader(btn, 'Saving…');
    const id = document.getElementById('custId').value;
    try {
        const payload = { first_name: fn, last_name: ln, email: em, phone: ph, source: document.getElementById('custSource').value };
        if (id) await API.customers.update(id, payload);
        else    await API.customers.create(payload);
        Utils.hideLoader(btn);
        custModalInstance?.hide();
        Utils.toast(`Customer ${id ? 'updated' : 'created'} successfully!`, 'success');
        loadCustomers(1);
    } catch (err) {
        Utils.hideLoader(btn);
        Utils.toast(err.message || 'Failed to save customer', 'error');
    }
}

function exportCsv() { Utils.toast('Export feature requires backend connection', 'info'); }

document.addEventListener('DOMContentLoaded', () => loadCustomers(1));
</script>
</body>
</html>
