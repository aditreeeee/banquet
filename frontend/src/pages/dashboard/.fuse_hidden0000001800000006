<style>
/* ── KPI row ── */
.kpi-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; margin-bottom:24px; }

/* ── Charts grid ── */
.charts-grid { display:grid; grid-template-columns:2fr 1fr; gap:16px; margin-bottom:24px; }
.charts-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:24px; }

/* ── Today's events ── */
.event-row { display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--border-color); }
.event-row:last-child { border-bottom:none; }
.event-time { font-size:11px; font-weight:600; color:var(--text-muted); min-width:55px; }
.event-dot  { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.event-name { font-size:13.5px; font-weight:600; color:var(--text-primary); }
.event-hall { font-size:12px; color:var(--text-muted); }
.event-guests { font-size:12px; color:var(--text-secondary); margin-left:auto; white-space:nowrap; }

/* ── Quick action cards ── */
.quick-actions { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px; }
.qa-card {
    background:var(--bg-surface); border:1px solid var(--border-color);
    border-radius:var(--radius-lg); padding:16px;
    text-decoration:none; text-align:center;
    transition:transform var(--transition-fast),box-shadow var(--transition-fast),border-color var(--transition-fast);
    cursor:pointer;
}
.qa-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); border-color:var(--brand-primary); }
.qa-icon { font-size:28px; margin-bottom:8px; }
.qa-label { font-size:12.5px; font-weight:600; color:var(--text-secondary); }

/* ── Skeleton for KPI ── */
.kpi-skeleton .kpi-value { background:var(--border-color); color:transparent; border-radius:4px; }
.kpi-skeleton .kpi-label { background:var(--border-color); color:transparent; border-radius:4px; margin-bottom:12px; }

@media (max-width:1100px) { .charts-grid { grid-template-columns:1fr; } .charts-grid-3 { grid-template-columns:1fr 1fr; } }
@media (max-width:768px) { .quick-actions { grid-template-columns:1fr 1fr; } .charts-grid-3 { grid-template-columns:1fr; } }
@media (max-width:480px) { .kpi-grid { grid-template-columns:1fr 1fr; } .quick-actions { grid-template-columns:1fr 1fr; } }
</style>
</head>
