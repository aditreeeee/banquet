<script>
/* ═══════════════════════════════════════════════════════
   DASHBOARD CONTROLLER
═══════════════════════════════════════════════════════ */
Auth.requireAuth('../auth/login.html');

let revenueChart, eventTypeChart, occupancyChart, calendar;

/* ── Greeting ── */
function setGreeting() {
    const h = new Date().getHours();
    const g = h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening';
    const user = Auth.getUser();
    document.getElementById('greetingTitle').textContent = `${g}, ${user?.first_name || 'there'} 👋`;
    document.getElementById('greetingDate').textContent =
        new Date().toLocaleDateString('en-IN', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
}

/* ── KPI Cards ── */
const KPI_DEFS = [
    { key:'today_bookings',   label:"Today's Bookings",  icon:'📅', colorIdx:0, format:'number' },
    { key:'month_revenue',    label:'Month Revenue',      icon:'💰', colorIdx:1, format:'currency' },
    { key:'upcoming_events',  label:'Upcoming Events',    icon:'🎉', colorIdx:2, format:'number' },
    { key:'active_customers', label:'Active Customers',   icon:'👥', colorIdx:4, format:'number' },
    { key:'occupancy_rate',   label:'Occupancy Rate',     icon:'🏢', colorIdx:5, format:'percent' },
    { key:'pending_payments', label:'Pending Collections',icon:'⏳', colorIdx:3, format:'currency' },
    { key:'total_halls',      label:'Active Halls',       icon:'🚪', colorIdx:6, format:'number' },
];

function renderKPIs(data) {
    const grid = document.getElementById('kpiGrid');
    grid.innerHTML = KPI_DEFS.map((k, i) => {
        const val    = data?.[k.key];
        const fmtVal = k.format === 'currency' ? Utils.formatCurrency(val)
                     : k.format === 'percent'  ? Utils.formatPercent(val)
                     : Utils.formatNumber(val);
        const delta  = data?.[k.key + '_delta'];
        const deltaHtml = delta !== undefined
            ? `<div class="kpi-delta ${delta >= 0 ? 'up' : 'down'}">
                ${delta >= 0 ? '↑' : '↓'} ${Math.abs(delta)}% vs last month
               </div>` : '';
        return `
        <div class="kpi-card" style="--accent:var(--kpi-${k.colorIdx + 1})">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
                <div>
                    <div class="kpi-label">${k.label}</div>
                    <div class="kpi-value">${fmtVal}</div>
                    ${deltaHtml}
                </div>
                <div class="kpi-icon-wrap" style="background:var(--kpi-${k.colorIdx + 1}-bg)">
                    <span style="font-size:20px;color:var(--kpi-${k.colorIdx + 1})">${k.icon}</span>
                </div>
            </div>
        </div>`;
    }).join('');
}

/* ── Revenue Chart ── */
function initRevenueChart(labels, revenues, bookingCounts) {
    const ctx = document.getElementById('revenueChart').getContext('2d');
    const isDark = Auth.getTheme() === 'dark';
    const gridColor = isDark ? 'rgba(255,255,255,.06)' : 'rgba(0,0,0,.06)';
    const textColor = isDark ? '#64748B' : '#94A3B8';

    if (revenueChart) revenueChart.destroy();
    revenueChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels,
            datasets: [
                {
                    label: 'Revenue (₹)',
                    data: revenues,
                    borderColor: '#7C3AED',
                    backgroundColor: 'rgba(124,58,237,.08)',
                    borderWidth: 2.5,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#7C3AED',
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    yAxisID: 'y',
                },
                {
                    label: 'Bookings',
                    data: bookingCounts,
                    borderColor: '#10B981',
                    backgroundColor: 'transparent',
                    borderWidth: 2,
                    tension: 0.4,
                    pointRadius: 3,
                    borderDash: [4, 3],
                    yAxisID: 'y1',
                }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { labels: { color: textColor, font: { size: 12 }, usePointStyle: true, pointStyleWidth: 12 }},
                tooltip: {
                    callbacks: {
                        label: ctx => ctx.datasetIndex === 0
                            ? ` Revenue: ${Utils.formatCurrency(ctx.parsed.y)}`
                            : ` Bookings: ${ctx.parsed.y}`
                    }
                }
            },
            scales: {
                x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 12 }}},
                y: {
                    position: 'left',
                    grid: { color: gridColor },
                    ticks: { color: textColor, font: { size: 11 }, callback: v => '₹' + Utils.formatNumber(v) }
                },
                y1: {
                    position: 'right',
                    grid: { drawOnChartArea: false },
                    ticks: { color: textColor, font: { size: 11 }}
                }
            }
        }
    });
}

/* ── Event Type Donut ── */
function initEventTypeChart(labels, counts) {
    const ctx = document.getElementById('eventTypeChart').getContext('2d');
    const colors = ['#7C3AED','#10B981','#F59E0B','#EF4444','#3B82F6','#EC4899','#14B8A6','#8B5CF6','#F97316','#06B6D4'];
    if (eventTypeChart) eventTypeChart.destroy();
    eventTypeChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels,
            datasets: [{
                data: counts,
                backgroundColor: colors.slice(0, labels.length),
                borderWidth: 2,
                borderColor: Auth.getTheme() === 'dark' ? '#151929' : '#ffffff',
                hoverOffset: 6,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { size: 11 }, usePointStyle: true, pointStyleWidth: 10,
                        color: Auth.getTheme() === 'dark' ? '#94A3B8' : '#475569' }
                }
            }
        }
    });
}

/* ── Occupancy Bar ── */
function initOccupancyChart(labels, values) {
    const ctx = document.getElementById('occupancyChart').getContext('2d');
    const isDark = Auth.getTheme() === 'dark';
    if (occupancyChart) occupancyChart.destroy();
    occupancyChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Occupancy %',
                data: values,
                backgroundColor: values.map(v => v >= 80 ? 'rgba(16,185,129,.7)' : v >= 50 ? 'rgba(245,158,11,.7)' : 'rgba(239,68,68,.7)'),
                borderRadius: 4,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            indexAxis: 'y',
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ` ${c.parsed.x.toFixed(1)}%` }}},
            scales: {
                x: {
                    max: 100,
                    grid: { color: isDark ? 'rgba(255,255,255,.05)' : 'rgba(0,0,0,.05)' },
                    ticks: { color: isDark ? '#64748B' : '#94A3B8', font: { size: 11 }, callback: v => v + '%' }
                },
                y: {
                    grid: { display: false },
                    ticks: { color: isDark ? '#64748B' : '#94A3B8', font: { size: 11 }}
                }
            }
        }
    });
}

/* ── FullCalendar ── */
function initCalendar(events) {
    const el = document.getElementById('bookingCalendar');
    if (!el) return;
    if (calendar) calendar.destroy();
    calendar = new FullCalendar.Calendar(el, {
        initialView: 'dayGridMonth',
        headerToolbar: { left: 'prev,next today', center: 'title', right: '' },
        height: 380,
        events,
        eventClick: ({ event }) => {
            if (event.extendedProps.booking_id) {
                window.location.href = `../bookings/detail.html?id=${event.extendedProps.booking_id}`;
            }
        },
        eventContent: ({ event }) => ({
            html: `<div style="padding:1px 4px;font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${event.title}</div>`
        }),
        dayMaxEvents: 3,
        eventClassNames: 'fc-event-custom',
    });
    calendar.render();
}

/* ── Today's Events ── */
function renderTodayEvents(events) {
    const container = document.getElementById('todayEvents');
    const badge     = document.getElementById('todayCount');
    badge.textContent = events.length;

    if (!events.length) {
        container.innerHTML = `<div class="empty-state" style="padding:24px">
            <div style="font-size:32px;margin-bottom:8px">🎉</div>
            <div style="font-size:13px;color:var(--text-muted)">No events today</div>
        </div>`;
        return;
    }

    container.innerHTML = events.map((e, i) => `
    <div class="event-row">
        <div class="event-time">${Utils.formatTime(e.start_time)}</div>
        <div class="event-dot" style="background:${Utils.eventColor(i)}"></div>
        <div style="flex:1;min-width:0">
            <div class="event-name truncate">${e.event_name}</div>
            <div class="event-hall">${e.hall_name} • ${e.banquet_name}</div>
        </div>
        <div class="event-guests">${Utils.formatNumber(e.expected_guests)} guests</div>
    </div>`).join('');
}

/* ── Recent Bookings Table ── */
function renderRecentBookings(bookings) {
    const tbody = document.getElementById('recentBookingsBody');
    if (!bookings?.length) {
        tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state">No recent bookings</div></td></tr>`;
        return;
    }
    tbody.innerHTML = bookings.map(b => `
    <tr>
        <td><a href="../bookings/detail.html?id=${b.booking_id}" style="color:var(--brand-primary);font-weight:600;text-decoration:none;font-family:var(--font-mono);font-size:12px">${b.booking_ref}</a></td>
        <td>${Utils.truncate(b.customer_name, 22)}</td>
        <td>${Utils.truncate(b.event_name || b.event_type, 20)}</td>
        <td style="white-space:nowrap">${Utils.formatDate(b.booking_date)}</td>
        <td>${Utils.truncate(b.hall_name || '—', 18)}</td>
        <td style="white-space:nowrap">${Utils.formatCurrency(b.grand_total)}</td>
        <td>${Utils.statusBadge(b.booking_status)}</td>
        <td>
            <a href="../bookings/detail.html?id=${b.booking_id}" class="btn-icon" title="View">👁</a>
        </td>
    </tr>`).join('');
}

/* ── Main load ── */
async function loadDashboard() {
    try {
        /* KPIs */
        const kpiRes = await API.dashboard.kpis({});
        renderKPIs(kpiRes.data);

        /* Revenue chart */
        const months = kpiRes.data?.revenue_trend || [];
        initRevenueChart(
            months.map(m => m.label),
            months.map(m => m.revenue),
            months.map(m => m.booking_count)
        );

        /* Event type donut */
        const etData = kpiRes.data?.event_type_breakdown || [];
        initEventTypeChart(etData.map(e => e.type_name), etData.map(e => e.count));

        /* Occupancy */
        const occData = kpiRes.data?.hall_occupancy || [];
        initOccupancyChart(
            occData.map(h => Utils.truncate(h.hall_name, 14)),
            occData.map(h => h.occupancy_pct)
        );

        /* Calendar */
        const calRes = await API.dashboard.calendar({});
        const calEvents = (calRes.data?.events || []).map((e, i) => ({
            id:    e.booking_id,
            title: e.event_name || e.event_type,
            start: e.booking_date,
            color: Utils.eventColor(i),
            extendedProps: { booking_id: e.booking_id }
        }));
        initCalendar(calEvents);

        /* Today's events */
        renderTodayEvents(kpiRes.data?.todays_events || []);

        /* Recent bookings */
        const bookRes = await API.bookings.list({ limit: 8, page: 1 });
        renderRecentBookings(bookRes.data?.bookings);

    } catch (err) {
        // Use demo/placeholder data if API not yet connected
        renderKPIs({
            today_bookings:   12,    today_bookings_delta:   8,
            month_revenue:    2850000, month_revenue_delta:  12,
            upcoming_events:  47,
            active_customers: 386,
            occupancy_rate:   73.5,
            pending_payments: 485000,
            total_halls:      11,
        });

        const demoMonths = ['Jan','Feb','Mar','Apr','May','Jun'];
        initRevenueChart(
            demoMonths,
            [1200000, 1800000, 2100000, 1600000, 2400000, 2850000],
            [18, 24, 31, 22, 38, 42]
        );
        initEventTypeChart(
            ['Wedding','Birthday','Corporate','Reception','Anniversary'],
            [42, 28, 35, 20, 15]
        );
        initOccupancyChart(
            ['Royal Ballroom','Crystal Hall','Garden Lawn','Maharaja Hall','Diamond Hall'],
            [85, 62, 78, 91, 55]
        );
        initCalendar([
            { id:1, title:'Wedding',   start: new Date().toISOString().split('T')[0], color:'#7C3AED' },
            { id:2, title:'Birthday',  start: new Date(Date.now()+86400000).toISOString().split('T')[0], color:'#10B981' },
            { id:3, title:'Corporate', start: new Date(Date.now()+172800000).toISOString().split('T')[0], color:'#F59E0B' },
        ]);
        renderTodayEvents([
            { start_time:'08:00', event_name:'Sharma Wedding Reception', hall_name:'Royal Ballroom', banquet_name:'Grand Events', expected_guests:450 },
            { start_time:'14:00', event_name:'Kapoor Birthday Bash',     hall_name:'Crystal Hall',   banquet_name:'Grand Events', expected_guests:120 },
            { start_time:'19:00', event_name:'Tech Summit Dinner',       hall_name:'Diamond Hall',   banquet_name:'Emerald CC',   expected_guests:200 },
        ]);
        renderRecentBookings([
            { booking_id:1, booking_ref:'BNQ-2026-000001', customer_name:'Arjun Sharma',  event_name:'Wedding Ceremony',     booking_date:'2026-07-15', hall_name:'Royal Ballroom', grand_total:225000, booking_status:'advance_paid' },
            { booking_id:2, booking_ref:'BNQ-2026-000002', customer_name:'Priya Patel',   event_name:'Birthday Celebration', booking_date:'2026-07-18', hall_name:'Crystal Hall',   grand_total:85000,  booking_status:'confirmed' },
            { booking_id:3, booking_ref:'BNQ-2026-000003', customer_name:'Rahul Gupta',   event_name:'Corporate Seminar',    booking_date:'2026-07-20', hall_name:'Executive Suite', grand_total:42000,  booking_status:'fully_paid' },
            { booking_id:4, booking_ref:'BNQ-2026-000004', customer_name:'Anjali Singh',  event_name:'Reception Dinner',     booking_date:'2026-07-22', hall_name:'Garden Lawn',    grand_total:148000, booking_status:'confirmed' },
            { booking_id:5, booking_ref:'BNQ-2026-000005', customer_name:'Vikram Mehta',  event_name:'Silver Anniversary',   booking_date:'2026-07-25', hall_name:'Terrace Lounge', grand_total:68000,  booking_status:'advance_paid' },
        ]);
    }
}

/* ── Init ── */
document.addEventListener('DOMContentLoaded', () => {
    setGreeting();
    loadDashboard();

    /* Re-draw charts on theme change */
    const observer = new MutationObserver(() => {
        if (revenueChart) { revenueChart.destroy(); revenueChart = null; }
        if (eventTypeChart) { eventTypeChart.destroy(); eventTypeChart = null; }
        if (occupancyChart) { occupancyChart.destroy(); occupancyChart = null; }
        loadDashboard();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    /* Revenue period change */
    document.getElementById('revenuePeriod')?.addEventListener('change', loadDashboard);
});
</script>
