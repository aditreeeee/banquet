<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bookings Report | Banquet System</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="../../public/assets/css/theme.css" rel="stylesheet">
<link href="../../public/assets/css/app.css"   rel="stylesheet">
</head>
<body>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
    <a href="../dashboard/index.html" class="sidebar-brand"><div class="sidebar-brand-icon">🏛</div><span class="sidebar-brand-text">BanquetPro</span></a>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a href="../dashboard/index.html" class="sidebar-link"><span class="sidebar-icon">📊</span><span class="sidebar-text">Dashboard</span></a>
        <div class="nav-section-label">Reports</div>
        <a href="revenue.html"   class="sidebar-link"><span class="sidebar-icon">📈</span><span class="sidebar-text">Revenue</span></a>
        <a href="bookings.html"  class="sidebar-link active"><span class="sidebar-icon">📋</span><span class="sidebar-text">Bookings</span></a>
        <a href="occupancy.html" class="sidebar-link"><span class="sidebar-icon">🏛</span><span class="sidebar-text">Occupancy</span></a>
    </nav>
    <div class="sidebar-footer"><div style="display:flex;align-items:center;gap:10px;padding:8px"><div class="avatar" data-user-avatar style="width:34px;height:34px;font-size:12px"></div><div class="sidebar-text"><div style="color:white;font-size:13px;font-weight:600" data-user-name></div></div></div></div>
</aside>

<div class="main-content" id="mainContent">
    <header class="topbar">
        <button class="topbar-toggle" id="sidebarToggle">☰</button>
        <nav class="breadcrumb-nav"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="../dashboard/index.html">Home</a></li><li class="breadcrumb-item">Reports</li><li class="breadcrumb-item active">Bookings</li></ol></nav>
        <div class="topbar-actions">
            <button class="topbar-btn" id="themeToggle"><span id="themeIcon">🌙</span></button>
            <div class="dropdown"><button class="avatar-btn" data-bs-toggle="dropdown"><div class="avatar" data-user-avatar></div></button><ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item danger" href="#" data-action="logout">🚪 Log Out</a></li></ul></div>
        </div>
    </header>

    <main class="page-content">
        <div class="page-header">
            <div><h1 class="page-title">Bookings Report</h1><p class="page-subtitle">Booking volume, status distribution and trends</p></div>
            <div style="display:flex;gap:8px">
                <button class="btn-ghost" onclick="Utils.toast('Exporting…','info')">⬇️ Export</button>
            </div>
        </div>

        <!-- Filters -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:14px 18px;margin-bottom:20px">
            <input type="date" id="fromDate" class="form-control" style="width:150px" onchange="loadReport()">
            <span style="color:var(--text-muted)">→</span>
            <input type="date" id="toDate"   class="form-control" style="width:150px" onchange="loadReport()">
            <select class="form-select" id="branchFilter" style="width:auto" onchange="loadReport()">
                <option value="">All Branches</option>
                <option value="1">Main Branch</option>
                <option value="2">North Branch</option>
            </select>
            <select class="form-select" id="statusFilter" style="width:auto" onchange="loadReport()">
                <option value="">All Statuses</option>
                <option value="confirmed">Confirmed</option>
                <option value="advance_paid">Advance Paid</option>
                <option value="fully_paid">Fully Paid</option>
                <option value="cancelled">Cancelled</option>
            </select>
        </div>

        <!-- KPIs -->
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:20px">
            <div class="kpi-card"><div class="kpi-label">Total Bookings</div><div class="kpi-value" id="kpiTotal">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Confirmed</div><div class="kpi-value" id="kpiConf" style="color:var(--color-success)">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Advance Paid</div><div class="kpi-value" id="kpiAdv" style="color:var(--brand-primary)">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Fully Paid</div><div class="kpi-value" id="kpiFull" style="color:var(--kpi-2)">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Cancelled</div><div class="kpi-value" id="kpiCancel" style="color:var(--color-danger)">—</div></div>
        </div>

        <!-- Charts row -->
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:16px;margin-bottom:20px">
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px">
                <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Bookings Trend</h6>
                <div style="height:220px"><canvas id="trendChart"></canvas></div>
            </div>
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px">
                <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">By Status</h6>
                <div style="height:220px"><canvas id="statusChart"></canvas></div>
            </div>
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px">
                <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">By Event Type</h6>
                <div style="height:220px"><canvas id="eventChart"></canvas></div>
            </div>
        </div>

        <!-- Detailed table -->
        <div class="table-card">
            <div style="padding:12px 16px;border-bottom:1px solid var(--border-color);font-weight:700;font-size:13px">Booking Details</div>
            <div class="table-responsive">
                <table class="table" style="font-size:12.5px">
                    <thead><tr><th>Period</th><th>Total</th><th>Confirmed</th><th>Advance Paid</th><th>Fully Paid</th><th>Cancelled</th><th>Cancel %</th><th>Avg Value</th></tr></thead>
                    <tbody id="reportBody"><tr><td colspan="8" class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></td></tr></tbody>
                </table>
            </div>
        </div>

    </main>
    <footer style="padding:16px 24px;border-top:1px solid var(--border-color);text-align:center;font-size:12px;color:var(--text-muted)">© 2026 BanquetPro</footer>
</div>

<div class="toast-container" id="toastContainer"></div>
<button id="scrollTop">↑</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="../../public/assets/js/api.js"></script>
<script src="../../public/assets/js/utils.js"></script>
<script src="../../public/assets/js/auth.js"></script>
<script src="../../public/assets/js/app.js"></script>
<script>
Auth.requireAuth('../auth/login.html');
let trendChart, statusChart, eventChart;

function getDemoData() {
    const months = ['Jan','Feb','Mar','Apr','May','Jun'];
    return {
        kpi:{ total:271, confirmed:42, advance_paid:95, fully_paid:118, cancelled:16 },
        trend:{ labels:months, datasets:[
            { label:'Total',       data:[38,42,41,49,54,47], borderColor:'#7C3AED', backgroundColor:'rgba(124,58,237,.08)', fill:true, tension:.35, borderWidth:2.5 },
            { label:'Cancelled',   data:[3,2,4,2,3,2],       borderColor:'#EF4444', borderDash:[4,2], fill:false, tension:.35, borderWidth:1.5 },
        ]},
        by_status:{ labels:['Confirmed','Advance Paid','Fully Paid','Cancelled'], data:[42,95,118,16] },
        by_event:{ labels:['Wedding','Reception','Birthday','Corporate','Engagement'], data:[85,52,48,44,28] },
        table: months.map((m,i)=>({ period:m+' 2026', total:[38,42,41,49,54,47][i], confirmed:Math.round([38,42,41,49,54,47][i]*.15), advance_paid:Math.round([38,42,41,49,54,47][i]*.35), fully_paid:Math.round([38,42,41,49,54,47][i]*.43), cancelled:[3,2,4,2,3,2][i], avg_value:[42000,47000,44000,50000,55000,48000][i] }))
    };
}

async function loadReport() {
    let data;
    try {
        const res = await API.reports.bookings({ from_date: document.getElementById('fromDate').value, to_date: document.getElementById('toDate').value, branch_id: document.getElementById('branchFilter').value || undefined, status: document.getElementById('statusFilter').value || undefined });
        data = res.data;
    } catch { data = getDemoData(); }
    const isDark = document.documentElement.getAttribute('data-theme')==='dark';
    const grid   = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)';
    const txt    = isDark ? '#9CA3AF' : '#6B7280';
    const k = data.kpi;
    document.getElementById('kpiTotal').textContent  = k.total;
    document.getElementById('kpiConf').textContent   = k.confirmed;
    document.getElementById('kpiAdv').textContent    = k.advance_paid;
    document.getElementById('kpiFull').textContent   = k.fully_paid;
    document.getElementById('kpiCancel').textContent = k.cancelled;
    if (trendChart)  { trendChart.destroy();  trendChart  = null; }
    if (statusChart) { statusChart.destroy(); statusChart = null; }
    if (eventChart)  { eventChart.destroy();  eventChart  = null; }
    trendChart = new Chart(document.getElementById('trendChart').getContext('2d'), { type:'line', data: data.trend, options:{ responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:txt,font:{size:11}}}},scales:{ x:{grid:{color:grid},ticks:{color:txt,font:{size:10}}}, y:{grid:{color:grid},ticks:{color:txt,font:{size:10}}} } } });
    statusChart = new Chart(document.getElementById('statusChart').getContext('2d'), { type:'doughnut', data:{ labels:data.by_status.labels, datasets:[{data:data.by_status.data,backgroundColor:['#10B981','#7C3AED','#2563EB','#EF4444'],borderWidth:0}] }, options:{ responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{ legend:{position:'bottom',labels:{color:txt,font:{size:11},boxWidth:10}} } } });
    eventChart  = new Chart(document.getElementById('eventChart').getContext('2d'),  { type:'bar',      data:{ labels:data.by_event.labels, datasets:[{data:data.by_event.data,backgroundColor:'rgba(124,58,237,.7)',borderRadius:4}] }, options:{ responsive:true,maintainAspectRatio:false,indexAxis:'y',plugins:{legend:{display:false}},scales:{ x:{grid:{color:grid},ticks:{color:txt,font:{size:10}}}, y:{grid:{color:'transparent'},ticks:{color:txt,font:{size:10}}} } } });
    document.getElementById('reportBody').innerHTML = data.table.map(r=>`
    <tr><td style="font-weight:600">${r.period}</td><td>${r.total}</td><td>${r.confirmed}</td><td>${r.advance_paid}</td><td>${r.fully_paid}</td><td style="color:var(--color-danger)">${r.cancelled}</td><td>${((r.cancelled/r.total)*100).toFixed(1)}%</td><td>${Utils.formatCurrency(r.avg_value)}</td></tr>`).join('');
}

new MutationObserver(loadReport).observe(document.documentElement,{attributes:true,attributeFilter:['data-theme']});
document.addEventListener('DOMContentLoaded',()=>{
    const now=new Date(); document.getElementById('toDate').value=now.toISOString().split('T')[0];
    const from=new Date(now.getFullYear(),0,1); document.getElementById('fromDate').value=from.toISOString().split('T')[0];
    loadReport();
});
</script>
</body>
</html>
