<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Occupancy Report | Banquet System</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="../../public/assets/css/theme.css" rel="stylesheet">
<link href="../../public/assets/css/app.css"   rel="stylesheet">
<style>
.occ-cell { display:flex;align-items:center;justify-content:center;height:100%;border-radius:4px;font-size:11.5px;font-weight:700;cursor:default }
.occ-high  { background:#D1FAE5;color:#065F46 }
.occ-mid   { background:#FEF3C7;color:#92400E }
.occ-low   { background:#FEE2E2;color:#991B1B }
.occ-zero  { background:var(--bg-surface-2);color:var(--text-muted) }
.legend-dot { width:12px;height:12px;border-radius:3px;display:inline-block;margin-right:4px }
</style>
</head>
<body>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
    <a href="../dashboard/index.html" class="sidebar-brand"><div class="sidebar-brand-icon">🏛</div><span class="sidebar-brand-text">BanquetPro</span></a>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Overview</div>
        <a href="../dashboard/index.html" class="sidebar-link"><span class="sidebar-icon">📊</span><span class="sidebar-text">Dashboard</span></a>
        <div class="nav-section-label">Reports</div>
        <a href="revenue.html"   class="sidebar-link"><span class="sidebar-icon">📈</span><span class="sidebar-text">Revenue</span></a>
        <a href="bookings.html"  class="sidebar-link"><span class="sidebar-icon">📋</span><span class="sidebar-text">Bookings</span></a>
        <a href="occupancy.html" class="sidebar-link active"><span class="sidebar-icon">🏛</span><span class="sidebar-text">Occupancy</span></a>
    </nav>
    <div class="sidebar-footer"><div style="display:flex;align-items:center;gap:10px;padding:8px"><div class="avatar" data-user-avatar style="width:34px;height:34px;font-size:12px"></div><div class="sidebar-text"><div style="color:white;font-size:13px;font-weight:600" data-user-name></div></div></div></div>
</aside>

<div class="main-content" id="mainContent">
    <header class="topbar">
        <button class="topbar-toggle" id="sidebarToggle">☰</button>
        <nav class="breadcrumb-nav"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="../dashboard/index.html">Home</a></li><li class="breadcrumb-item">Reports</li><li class="breadcrumb-item active">Occupancy</li></ol></nav>
        <div class="topbar-actions">
            <button class="topbar-btn" id="themeToggle"><span id="themeIcon">🌙</span></button>
            <div class="dropdown"><button class="avatar-btn" data-bs-toggle="dropdown"><div class="avatar" data-user-avatar></div></button><ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item danger" href="#" data-action="logout">🚪 Log Out</a></li></ul></div>
        </div>
    </header>

    <main class="page-content">
        <div class="page-header">
            <div><h1 class="page-title">Occupancy Report</h1><p class="page-subtitle">Hall utilization rates, peak times and availability patterns</p></div>
            <button class="btn-ghost" onclick="Utils.toast('Exporting…','info')">⬇️ Export</button>
        </div>

        <!-- Filters -->
        <div style="display:flex;gap:10px;align-items:center;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:14px 18px;margin-bottom:20px;flex-wrap:wrap">
            <input type="month" id="monthPicker" onchange="loadReport()" class="form-control" style="width:160px">
            <select class="form-select" id="branchFilter" onchange="loadReport()" style="width:auto">
                <option value="">All Branches</option>
                <option value="1">Main Branch</option>
                <option value="2">North Branch</option>
            </select>
            <select class="form-select" id="hallFilter" onchange="loadReport()" style="width:auto">
                <option value="">All Halls</option>
                <option value="1">Grand Ballroom</option>
                <option value="2">Emerald Hall</option>
                <option value="3">Royal Suite</option>
                <option value="4">Silver Terrace</option>
            </select>
        </div>

        <!-- KPIs -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px">
            <div class="kpi-card"><div class="kpi-label">Avg Occupancy</div><div class="kpi-value" id="kpiAvg" style="color:var(--color-success)">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Peak Day</div><div class="kpi-value" id="kpiPeak" style="font-size:16px">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Total Booked Days</div><div class="kpi-value" id="kpiBooked">—</div></div>
            <div class="kpi-card"><div class="kpi-label">Available Days</div><div class="kpi-value" id="kpiAvail">—</div></div>
        </div>

        <!-- Charts + heatmap grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
            <!-- Occupancy by hall bar chart -->
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px">
                <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Occupancy by Hall</h6>
                <div style="height:240px"><canvas id="hallChart"></canvas></div>
            </div>
            <!-- Weekday distribution -->
            <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px">
                <h6 style="font-size:13px;font-weight:700;margin-bottom:14px">Bookings by Day of Week</h6>
                <div style="height:240px"><canvas id="weekChart"></canvas></div>
            </div>
        </div>

        <!-- Calendar heatmap -->
        <div style="background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px;margin-bottom:20px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
                <h6 style="font-size:13px;font-weight:700;margin:0">Monthly Heatmap</h6>
                <div style="display:flex;gap:10px;font-size:12px;align-items:center">
                    <span><span class="legend-dot" style="background:#D1FAE5"></span>High (≥80%)</span>
                    <span><span class="legend-dot" style="background:#FEF3C7"></span>Mid (≥50%)</span>
                    <span><span class="legend-dot" style="background:#FEE2E2"></span>Low (<50%)</span>
                    <span><span class="legend-dot" style="background:var(--bg-surface-2)"></span>No bookings</span>
                </div>
            </div>
            <div id="calHeatmap"></div>
        </div>

        <!-- Hall summary table -->
        <div class="table-card">
            <div style="padding:12px 16px;border-bottom:1px solid var(--border-color);font-weight:700;font-size:13px">Hall Summary</div>
            <div class="table-responsive">
                <table class="table" style="font-size:12.5px">
                    <thead><tr><th>Hall</th><th>Capacity</th><th>Booked Days</th><th>Available Days</th><th>Occupancy %</th><th>Revenue</th><th>Avg Rating</th></tr></thead>
                    <tbody id="hallTableBody"><tr><td colspan="7" class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></td></tr></tbody>
                </table>
            </div>
        </div>

    </main>
    <footer style="padding:16px 24px;border-top:1px solid var(--border-color);text-align:center;font-size:12px;color:var(--text-muted)">© 2026 BanquetPro</footer>
</div>

<div class="toast-container" id="toastContainer"></div>
<button id="scrollTop">↑</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="../../public/assets/js/api.js"></script>
<script src="../../public/assets/js/utils.js"></script>
<script src="../../public/assets/js/auth.js"></script>
<script src="../../public/assets/js/app.js"></script>
<script>
Auth.requireAuth('../auth/login.html');
let hallChart, weekChart;

const HALLS = ['Grand Ballroom','Emerald Hall','Royal Suite','Silver Terrace','Diamond Hall'];
const HALL_OCC = [84, 71, 67, 58, 43];

function getDemoData(year, month) {
    const daysInMonth = new Date(year, month, 0).getDate();
    const calData = Array.from({length:daysInMonth},(_,i)=>{
        const day = i+1;
        const dow = new Date(year,month-1,day).getDay();
        const isWeekend = dow===0||dow===6;
        const base = isWeekend ? 0.85 : 0.55;
        const occ  = Math.min(1, base + (Math.random()-.4)*.5);
        return { day, occ: parseFloat(occ.toFixed(2)) };
    });
    return {
        kpi: { avg_occ: 67, peak_day: 'Saturday', booked_days: 136, avail_days: 64 },
        by_hall: { labels: HALLS, data: HALL_OCC },
        by_weekday: { labels:['Sun','Mon','Tue','Wed','Thu','Fri','Sat'], data:[45,22,18,24,28,38,72] },
        cal: calData,
        table: HALLS.map((h,i)=>({ hall_name:h, capacity:[500,350,200,400,600][i], booked:[22,18,16,12,8][i], avail:[8,12,14,18,22][i], occ:HALL_OCC[i], revenue:[2140000,1380000,950000,780000,480000][i], avg_rating:[4.7,4.5,4.3,4.1,3.9][i] })),
    };
}

async function loadReport() {
    const monthVal = document.getElementById('monthPicker').value;
    const [year, month] = monthVal.split('-').map(Number);
    let data;
    try {
        const res = await API.reports.occupancy({ month: monthVal, branch_id: document.getElementById('branchFilter').value || undefined });
        data = res.data;
    } catch { data = getDemoData(year, month); }
    const isDark = document.documentElement.getAttribute('data-theme')==='dark';
    const grid   = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)';
    const txt    = isDark ? '#9CA3AF' : '#6B7280';
    document.getElementById('kpiAvg').textContent    = data.kpi.avg_occ + '%';
    document.getElementById('kpiPeak').textContent   = data.kpi.peak_day;
    document.getElementById('kpiBooked').textContent = data.kpi.booked_days;
    document.getElementById('kpiAvail').textContent  = data.kpi.avail_days;
    if (hallChart) hallChart.destroy();
    if (weekChart) weekChart.destroy();
    hallChart = new Chart(document.getElementById('hallChart').getContext('2d'), {
        type:'bar',
        data:{ labels: data.by_hall.labels, datasets:[{ data: data.by_hall.data, backgroundColor: data.by_hall.data.map(v=>v>=80?'#10B981':v>=50?'#F59E0B':'#EF4444'), borderRadius:5 }] },
        options:{ responsive:true,maintainAspectRatio:false,indexAxis:'y',plugins:{legend:{display:false}},scales:{ x:{grid:{color:grid},ticks:{color:txt,callback:v=>v+'%'},min:0,max:100}, y:{grid:{color:'transparent'},ticks:{color:txt,font:{size:11}}} } }
    });
    weekChart = new Chart(document.getElementById('weekChart').getContext('2d'), {
        type:'bar',
        data:{ labels: data.by_weekday.labels, datasets:[{ data: data.by_weekday.data, backgroundColor:'rgba(124,58,237,.7)', borderRadius:4 }] },
        options:{ responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{ x:{grid:{color:grid},ticks:{color:txt}}, y:{grid:{color:grid},ticks:{color:txt}} } }
    });
    renderHeatmap(data.cal, year, month);
    renderHallTable(data.table);
}

function renderHeatmap(calData, year, month) {
    const firstDow = new Date(year, month-1, 1).getDay();
    const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    let html = `<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px">`;
    days.forEach(d=>{ html+=`<div style="text-align:center;font-size:11px;color:var(--text-muted);padding:4px;font-weight:600">${d}</div>`; });
    for(let i=0;i<firstDow;i++) html+=`<div></div>`;
    calData.forEach(({day,occ})=>{
        const cls = occ===0?'occ-zero':occ>=.8?'occ-high':occ>=.5?'occ-mid':'occ-low';
        html+=`<div style="height:52px;padding:2px"><div class="occ-cell ${cls}" title="Day ${day}: ${Math.round(occ*100)}% occupied"><div style="font-size:13px;font-weight:700">${day}</div><div style="font-size:10px">${occ>0?Math.round(occ*100)+'%':''}</div></div></div>`;
    });
    html+=`</div>`;
    document.getElementById('calHeatmap').innerHTML = html;
}

function renderHallTable(halls) {
    document.getElementById('hallTableBody').innerHTML = halls.map(h=>`
    <tr>
        <td style="font-weight:600">${h.hall_name}</td>
        <td>${h.capacity}</td>
        <td>${h.booked}</td>
        <td>${h.avail}</td>
        <td><div style="display:flex;align-items:center;gap:8px"><div style="flex:1;height:7px;background:var(--bg-surface-2);border-radius:4px"><div style="height:100%;border-radius:4px;background:${h.occ>=80?'#10B981':h.occ>=50?'#F59E0B':'#EF4444'};width:${h.occ}%"></div></div><span style="font-weight:700;min-width:36px">${h.occ}%</span></div></td>
        <td style="font-weight:700">${Utils.formatCurrency(h.revenue)}</td>
        <td>⭐ ${h.avg_rating?.toFixed(1)}</td>
    </tr>`).join('');
}

new MutationObserver(loadReport).observe(document.documentElement,{attributes:true,attributeFilter:['data-theme']});
document.addEventListener('DOMContentLoaded',()=>{
    const now=new Date();
    document.getElementById('monthPicker').value=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
    loadReport();
});
</script>
</body>
</html>
